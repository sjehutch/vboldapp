                                                                                         [out] double* ElapsedTime,
                                                                                         [out] DATE* LastPeakDateTime,
                                                                                         [out] DATE* HLTDateTime, 
                                                                                         [out] BSTR* Msg );

      [id(8), helpstring("method SetConcentration")] HRESULT SetConcentration( [in] double Concentration, 
