      [id(18), helpstring("method GetLifeStageTotal")] HRESULT GetLifeStageTotal( [out, retval] int* Total );
		
      [id(19), helpstring("method GetLifeStageIndex")] HRESULT GetLifeStageIndex( [in] BSTR* LifeStage, 
